{
  "name": "@plur-ai/claw",
  "version": "0.9.8",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claw": "dist/cli.js"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.0"
    },
    "build": {
      "openclawVersion": "2026.3.7"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "postinstall": "node dist/setup.js 2>/dev/null || true"
  },
  "dependencies": {
    "@plur-ai/core": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "license": "Apache-2.0",
  "description": "PLUR memory plugin for OpenClaw — persistent learning across sessions",
  "keywords": [
    "ai",
    "memory",
    "openclaw",
    "context-engine",
    "plugin",
    "agent",
    "learning"
  ],
  "homepage": "https://plur.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/plur-ai/plur",
    "directory": "packages/claw"
  },
  "author": "PLUR <info@plur.ai>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
